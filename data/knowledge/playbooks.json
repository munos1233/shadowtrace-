  "description": "SOAR playbook knowledge base — standard response procedures by event type and severity",
  "playbooks": [
    {
      "playbook_id": "pb-a1b2c3d4",
      "playbook_name": "Account Anomaly Credential Compromise Response",
      "event_type": "account_anomaly",
      "min_severity": "high",
      "description": "Respond to high-severity account anomalies with credential rotation, session termination, and account disabling.",
      "steps": [
        {
          "step_order": 1,
          "action_name": "Query Account Login History",
          "tool_name": "query_account_login",
          "action_level": "l0",
          "precondition": "Account identifier is known",
          "expected_outcome": "Login timeline and geolocation anomalies identified",
          "required_capabilities": []
        },
        {
          "step_order": 2,
          "action_name": "Disable Compromised Account",
          "tool_name": "disable_account",
          "action_level": "l3",
          "precondition": "Account confirmed as compromised",
          "expected_outcome": "Account disabled; lateral movement blocked",
          "required_capabilities": ["entity_response"]
        },
        {
          "step_order": 3,
          "action_name": "Force Logout All Sessions",
          "tool_name": "force_logout",
          "action_level": "l3",
          "precondition": "Account disabled successfully",
          "expected_outcome": "All active sessions terminated",
          "required_capabilities": ["entity_response"]
        },
        {
          "step_order": 4,
          "action_name": "Reset Account Password",
          "tool_name": "reset_password",
          "action_level": "l4",
          "precondition": "Account owner identity verified",
          "expected_outcome": "Password rotated; unauthorized access revoked",
          "required_capabilities": ["entity_response"]
        },
        {
          "step_order": 5,
          "action_name": "Revoke Access Tokens",
          "tool_name": "revoke_token",
          "action_level": "l4",
          "precondition": "Password reset completed",
          "expected_outcome": "All issued tokens and sessions invalidated",
          "required_capabilities": ["entity_response"]
        },
        {
          "step_order": 6,
          "action_name": "Create Security Ticket",
          "tool_name": "create_ticket",
          "action_level": "l1",
          "precondition": "Initial containment actions executed",
          "expected_outcome": "Ticket created for tracking and audit",
          "required_capabilities": ["entity_response"]
        },
        {
          "step_order": 7,
          "action_name": "Notify Security Team",
          "tool_name": "notify_security_team",
          "action_level": "l1",
          "precondition": "All prior steps completed",
          "expected_outcome": "Security team alerted with incident summary",
          "required_capabilities": ["entity_response"]
        }
      ]
    },
