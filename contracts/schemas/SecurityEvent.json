{
  "$defs": {
    "AccountEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "account",
          "default": "account",
          "title": "Entity Type",
          "type": "string"
        },
        "username": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Username"
        },
        "domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Domain"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "AccountEntity",
      "type": "object"
    },
    "DispositionPolicy": {
      "enum": [
        "required",
        "not_required"
      ],
      "title": "DispositionPolicy",
      "type": "string"
    },
    "DomainEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "domain",
          "default": "domain",
          "title": "Entity Type",
          "type": "string"
        },
        "fqdn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fqdn"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "DomainEntity",
      "type": "object"
    },
    "EntitySet": {
      "additionalProperties": false,
      "description": "Container of the six entity categories.",
      "properties": {
        "accounts": {
          "items": {
            "$ref": "#/$defs/AccountEntity"
          },
          "title": "Accounts",
          "type": "array"
        },
        "hosts": {
          "items": {
            "$ref": "#/$defs/HostEntity"
          },
          "title": "Hosts",
          "type": "array"
        },
        "ips": {
          "items": {
            "$ref": "#/$defs/IPEntity"
          },
          "title": "Ips",
          "type": "array"
        },
        "domains": {
          "items": {
            "$ref": "#/$defs/DomainEntity"
          },
          "title": "Domains",
          "type": "array"
        },
        "processes": {
          "items": {
            "$ref": "#/$defs/ProcessEntity"
          },
          "title": "Processes",
          "type": "array"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/FileEntity"
          },
          "title": "Files",
          "type": "array"
        }
      },
      "title": "EntitySet",
      "type": "object"
    },
    "EventStatus": {
      "description": "ShadowTrace internal investigation orchestration state (14 states).",
      "enum": [
        "new",
        "triaging",
        "collecting_evidence",
        "analyzing",
        "scoring",
        "planning_response",
        "waiting_approval",
        "executing_response",
        "verifying",
        "replanning",
        "contained",
        "failed",
        "reporting",
        "closed"
      ],
      "title": "EventStatus",
      "type": "string"
    },
    "EventType": {
      "description": "Supported security event types (intro §1); extensible via scenario packs.",
      "enum": [
        "account_anomaly",
        "host_compromise",
        "data_exfiltration",
        "insider_threat",
        "malicious_process",
        "suspicious_domain",
        "lateral_movement",
        "other"
      ],
      "title": "EventType",
      "type": "string"
    },
    "FileEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "file",
          "default": "file",
          "title": "Entity Type",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hash"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "FileEntity",
      "type": "object"
    },
    "FinalVerdict": {
      "description": "Verdict label, independent from EventStatus.",
      "enum": [
        "none",
        "possible_false_positive",
        "false_positive",
        "confirmed_threat"
      ],
      "title": "FinalVerdict",
      "type": "string"
    },
    "HostEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
