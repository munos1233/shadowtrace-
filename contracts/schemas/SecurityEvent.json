        },
        "os": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Os"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "HostEntity",
      "type": "object"
    },
    "IPEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "ip",
          "default": "ip",
          "title": "Entity Type",
          "type": "string"
        },
        "address": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Address"
        },
        "scope": {
          "default": "unknown",
          "enum": [
            "external",
            "internal",
            "unknown"
          ],
          "title": "Scope",
          "type": "string"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "IPEntity",
      "type": "object"
    },
    "ProcessEntity": {
      "additionalProperties": false,
      "properties": {
        "entity_id": {
          "title": "Entity Id",
          "type": "string"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceReference"
          },
          "title": "Source Refs",
          "type": "array"
        },
        "attributes": {
          "additionalProperties": true,
          "title": "Attributes",
          "type": "object"
        },
        "entity_type": {
          "const": "process",
          "default": "process",
          "title": "Entity Type",
          "type": "string"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Name"
        },
        "pid": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pid"
        },
        "command_line": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Command Line"
        },
        "hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Hash"
        }
      },
      "required": [
        "entity_id"
      ],
      "title": "ProcessEntity",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    },
    "SourceDisposition": {
      "description": "Normalized external disposition label; source_status_raw keeps the original.",
      "enum": [
        "pending",
        "processing",
        "contained",
        "completed",
        "suspended",
        "ignored",
        "unknown"
      ],
      "title": "SourceDisposition",
      "type": "string"
    },
    "SourceObjectKind": {
      "description": "Canonical source object kind used for the internal discriminated union.",
      "enum": [
        "incident",
        "alert",
        "asset",
        "log",
        "connector"
      ],
      "title": "SourceObjectKind",
      "type": "string"
    },
    "SourceObjectLocator": {
      "additionalProperties": false,
      "description": "Minimal writeback locator (intro §4.3.5 / ISSUE-002).",
      "properties": {
        "source_product": {
          "title": "Source Product",
          "type": "string"
        },
        "source_tenant_id": {
          "title": "Source Tenant Id",
          "type": "string"
        },
        "connector_id": {
          "title": "Connector Id",
          "type": "string"
        },
        "source_kind": {
          "$ref": "#/$defs/SourceObjectKind"
        },
        "source_object_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Object Type"
        },
        "source_object_id": {
          "title": "Source Object Id",
          "type": "string"
        }
      },
      "required": [
        "source_product",
        "source_tenant_id",
        "connector_id",
        "source_kind",
        "source_object_id"
      ],
      "title": "SourceObjectLocator",
      "type": "object"
    },
    "SourceReference": {
      "additionalProperties": false,
      "description": "Immutable snapshot reference to an external source object (intro §4.3).\n\nIdentity five-tuple is\n``(source_product, source_tenant_id, connector_id, source_kind, source_object_id)``.\nThe adapter-native ``source_object_type`` and opaque ``source_concurrency_token``\ndo NOT participate in identity.",
      "properties": {
        "source_kind": {
          "$ref": "#/$defs/SourceObjectKind"
        },
        "source_product": {
          "title": "Source Product",
          "type": "string"
        },
        "source_tenant_id": {
          "title": "Source Tenant Id",
          "type": "string"
        },
        "connector_id": {
          "title": "Connector Id",
          "type": "string"
        },
        "source_object_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Object Type"
        },
        "source_object_id": {
          "title": "Source Object Id",
          "type": "string"
        },
        "parent_source_object_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Source Object Id"
        },
        "source_status_raw": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Status Raw"
        },
        "source_disposition": {
          "$ref": "#/$defs/SourceDisposition",
          "default": "unknown"
        },
        "source_concurrency_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Concurrency Token"
        },
        "source_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Updated At"
        },
        "schema_version": {
          "default": "1",
          "title": "Schema Version",
          "type": "string"
        },
        "ingested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ingested At"
        },
        "raw_payload_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Payload Hash"
        }
      },
      "required": [
        "source_kind",
        "source_product",
        "source_tenant_id",
        "connector_id",
        "source_object_id"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "event_type": {
      "$ref": "#/$defs/EventType"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/EventStatus",
      "default": "new"
    },
    "severity": {
      "$ref": "#/$defs/Severity",
      "default": "low"
    },
    "risk_score": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Risk Score",
      "type": "integer"
    },
    "confidence": {
      "default": 0.0,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "final_verdict": {
      "$ref": "#/$defs/FinalVerdict",
      "default": "none"
    },
    "entities": {
      "$ref": "#/$defs/EntitySet"
    },
    "creation_source_ref": {
      "$ref": "#/$defs/SourceReference"
    },
    "source_reference_snapshots": {
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Source Reference Snapshots",
      "type": "array"
    },
    "current_primary_source_record_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Current Primary Source Record Id"
    },
    "disposition_source_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/SourceObjectLocator"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "disposition_policy": {
      "$ref": "#/$defs/DispositionPolicy",
      "default": "not_required"
    },
    "raw_alert_ids": {
      "items": {
        "type": "string"
      },
      "title": "Raw Alert Ids",
      "type": "array"
    },
    "raw_alert_snapshot": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Alert Snapshot"
    },
    "source_type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Type"
    },
    "occurred_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Occurred At"
    },
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "closed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Closed At"
    },
    "replan_count": {
      "default": 0,
      "title": "Replan Count",
      "type": "integer"
    },
    "degraded_flags": {
      "items": {
        "type": "string"
      },
      "title": "Degraded Flags",
      "type": "array"
    },
    "escalated": {
      "default": false,
      "title": "Escalated",
      "type": "boolean"
    },
    "external_unsynced": {
      "default": false,
      "title": "External Unsynced",
      "type": "boolean"
    },
    "event_context_snapshot": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Event Context Snapshot"
    },
    "row_version": {
      "default": 1,
      "minimum": 1,
      "title": "Row Version",
      "type": "integer"
    }
  },
  "required": [
    "event_id",
    "event_type",
    "title",
    "creation_source_ref"
  ],
  "title": "SecurityEvent",
  "type": "object"
}
