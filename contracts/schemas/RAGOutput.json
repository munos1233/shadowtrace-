{
  "$defs": {
    "AttackTechniqueMatch": {
      "additionalProperties": false,
      "properties": {
        "technique_id": {
          "title": "Technique Id",
          "type": "string"
        },
        "technique_name": {
          "title": "Technique Name",
          "type": "string"
        },
        "tactics": {
          "items": {
            "type": "string"
          },
          "title": "Tactics",
          "type": "array"
        },
        "match_confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Match Confidence",
          "type": "number"
        },
        "citation_id": {
          "title": "Citation Id",
          "type": "string"
        }
      },
      "required": [
        "technique_id",
        "technique_name",
        "match_confidence",
        "citation_id"
      ],
      "title": "AttackTechniqueMatch",
      "type": "object"
    },
    "Citation": {
      "additionalProperties": false,
      "properties": {
        "citation_id": {
          "title": "Citation Id",
          "type": "string"
        },
        "chunk_id": {
          "title": "Chunk Id",
          "type": "string"
        },
        "kb_name": {
          "title": "Kb Name",
          "type": "string"
        },
        "quoted_text": {
          "title": "Quoted Text",
          "type": "string"
        },
        "relevance_score": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Relevance Score",
          "type": "number"
        }
      },
      "required": [
        "citation_id",
        "chunk_id",
        "kb_name",
        "quoted_text",
        "relevance_score"
      ],
      "title": "Citation",
      "type": "object"
    },
    "EventType": {
      "description": "Supported security event types (intro §1); extensible via scenario packs.",
      "enum": [
        "account_anomaly",
        "host_compromise",
        "data_exfiltration",
        "insider_threat",
        "malicious_process",
        "suspicious_domain",
        "lateral_movement",
        "other"
      ],
      "title": "EventType",
      "type": "string"
    },
    "FinalVerdict": {
      "description": "Verdict label, independent from EventStatus.",
      "enum": [
        "none",
        "possible_false_positive",
        "false_positive",
        "confirmed_threat"
      ],
      "title": "FinalVerdict",
      "type": "string"
    },
    "FpSimilarity": {
      "additionalProperties": false,
      "properties": {
        "max_score": {
          "default": 0.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Max Score",
          "type": "number"
        },
        "matched_case_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched Case Id"
        },
        "matched_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched Pattern"
        }
      },
      "title": "FpSimilarity",
      "type": "object"
    },
    "SimilarCaseSummary": {
      "additionalProperties": false,
      "description": "Compact HistoryCase digest for RAG similar_cases (full model lands later).",
      "properties": {
        "case_id": {
          "title": "Case Id",
          "type": "string"
        },
        "event_type": {
          "anyOf": [
            {
              "$ref": "#/$defs/EventType"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "summary": {
          "default": "",
          "title": "Summary",
          "type": "string"
        },
        "final_verdict": {
          "anyOf": [
            {
              "$ref": "#/$defs/FinalVerdict"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "risk_score": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Risk Score"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        }
      },
      "required": [
        "case_id"
      ],
      "title": "SimilarCaseSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "attack_techniques": {
      "items": {
        "$ref": "#/$defs/AttackTechniqueMatch"
      },
      "title": "Attack Techniques",
      "type": "array"
    },
    "fp_similarity": {
      "$ref": "#/$defs/FpSimilarity"
    },
    "similar_cases": {
      "items": {
        "$ref": "#/$defs/SimilarCaseSummary"
      },
      "title": "Similar Cases",
      "type": "array"
    },
    "playbook_refs": {
      "items": {
        "type": "string"
      },
      "title": "Playbook Refs",
      "type": "array"
    },
    "citations": {
      "items": {
        "$ref": "#/$defs/Citation"
      },
      "title": "Citations",
      "type": "array"
    },
    "degraded": {
      "default": false,
      "title": "Degraded",
      "type": "boolean"
    }
  },
  "title": "RAGOutput",
  "type": "object"
}
