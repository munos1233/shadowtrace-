{
  "$defs": {
    "ActionExecutionJob": {
      "additionalProperties": false,
      "properties": {
        "job_id": {
          "title": "Job Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "provider_name": {
          "title": "Provider Name",
          "type": "string"
        },
        "idempotency_key": {
          "title": "Idempotency Key",
          "type": "string"
        },
        "provider_job_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Job Id"
        },
        "status": {
          "$ref": "#/$defs/ExecutionJobStatus",
          "default": "queued"
        },
        "claimed_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Claimed By"
        },
        "lease_expires_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Lease Expires At"
        },
        "created_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Started At"
        },
        "finished_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finished At"
        },
        "poll_after_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Poll After Ms"
        },
        "attempt": {
          "default": 0,
          "title": "Attempt",
          "type": "integer"
        },
        "target_results": {
          "items": {
            "$ref": "#/$defs/TargetExecutionResult"
          },
          "title": "Target Results",
          "type": "array"
        },
        "provider_code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Code"
        },
        "provider_message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Message"
        },
        "raw_result": {
          "additionalProperties": true,
          "title": "Raw Result",
          "type": "object"
        }
      },
      "required": [
        "job_id",
        "event_id",
        "action_id",
        "provider_name",
        "idempotency_key"
      ],
      "title": "ActionExecutionJob",
      "type": "object"
    },
    "ActionExecutionPhase": {
      "enum": [
        "immediate",
        "post_verify"
      ],
      "title": "ActionExecutionPhase",
      "type": "string"
    },
    "ActionStatus": {
      "description": "Action lifecycle state (11 states).",
      "enum": [
        "pending",
        "waiting_approval",
        "approved",
        "rejected",
        "superseded",
        "executing",
        "partial_success",
        "success",
        "failed",
        "unknown",
        "rolled_back"
      ],
      "title": "ActionStatus",
      "type": "string"
    },
    "DispositionPolicy": {
      "enum": [
        "required",
        "not_required"
      ],
      "title": "DispositionPolicy",
      "type": "string"
    },
    "ExecutionActionView": {
      "additionalProperties": false,
      "description": "Per-action projection used inside ExecutionSummary.",
      "properties": {
        "action_id": {
          "title": "Action Id",
          "type": "string"
        },
        "action_status": {
          "$ref": "#/$defs/ActionStatus"
        },
        "execution_phase": {
          "$ref": "#/$defs/ActionExecutionPhase"
        },
        "writeback_required": {
          "title": "Writeback Required",
          "type": "boolean"
        },
        "writeback_applicable": {
          "title": "Writeback Applicable",
          "type": "boolean"
        },
        "writeback_readiness": {
          "$ref": "#/$defs/WritebackReadiness"
        },
        "writeback_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/WritebackStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "target_results": {
          "items": {
            "$ref": "#/$defs/TargetExecutionResult"
          },
          "title": "Target Results",
          "type": "array"
        }
      },
      "required": [
        "action_id",
        "action_status",
        "execution_phase",
        "writeback_required",
        "writeback_applicable",
        "writeback_readiness"
      ],
      "title": "ExecutionActionView",
      "type": "object"
    },
    "ExecutionJobStatus": {
      "enum": [
        "queued",
        "running",
        "partial_success",
        "success",
        "failed",
        "timed_out",
        "cancelled",
        "unknown"
      ],
      "title": "ExecutionJobStatus",
      "type": "string"
    },
    "SourceDisposition": {
      "description": "Normalized external disposition label; source_status_raw keeps the original.",
      "enum": [
        "pending",
        "processing",
        "contained",
        "completed",
        "suspended",
        "ignored",
        "unknown"
      ],
      "title": "SourceDisposition",
      "type": "string"
    },
    "TargetExecutionResult": {
      "additionalProperties": false,
      "description": "Per-target execution result kept on a job (internal; may retain raw_result).",
      "properties": {
        "canonical_target": {
          "title": "Canonical Target",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/TargetExecutionStatus"
        },
        "code": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Code"
        },
        "message": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Message"
        },
        "artifact_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Artifact Id"
        },
        "raw_result": {
          "additionalProperties": true,
          "title": "Raw Result",
          "type": "object"
        }
      },
      "required": [
        "canonical_target",
        "status"
      ],
      "title": "TargetExecutionResult",
      "type": "object"
    },
    "TargetExecutionStatus": {
      "enum": [
        "success",
        "failed",
        "unknown",
        "skipped"
      ],
      "title": "TargetExecutionStatus",
      "type": "string"
    },
    "WritebackReadiness": {
      "description": "Pre-submission condition; not an external receipt.",
      "enum": [
        "not_required",
        "ready",
        "source_unresolved",
        "not_configured",
        "capability_unknown",
        "capability_unsupported",
        "permission_denied",
        "connector_unavailable"
      ],
      "title": "WritebackReadiness",
      "type": "string"
    },
    "WritebackStatus": {
      "description": "Only valid once a writeback command exists; null otherwise.",
      "enum": [
        "pending",
        "sending",
        "accepted",
        "confirmed",
        "partial",
        "failed",
        "conflict",
        "unknown"
      ],
      "title": "WritebackStatus",
      "type": "string"
    },
    "WritebackSummary": {
      "additionalProperties": false,
      "description": "Aggregate writeback view (single source of truth for the CLOSED gate).",
      "properties": {
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "closure_cycle": {
          "title": "Closure Cycle",
          "type": "integer"
        },
        "disposition_policy": {
          "$ref": "#/$defs/DispositionPolicy"
        },
        "required_action_count": {
          "default": 0,
          "title": "Required Action Count",
          "type": "integer"
        },
        "applicable_action_count": {
          "default": 0,
          "title": "Applicable Action Count",
          "type": "integer"
        },
        "blocked_action_ids": {
          "items": {
            "type": "string"
          },
          "title": "Blocked Action Ids",
          "type": "array"
        },
        "readiness_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "propertyNames": {
            "$ref": "#/$defs/WritebackReadiness"
          },
          "title": "Readiness Counts",
          "type": "object"
        },
        "aggregate_readiness": {
          "$ref": "#/$defs/WritebackReadiness",
          "default": "not_required"
        },
        "writeback_counts": {
          "additionalProperties": {
            "type": "integer"
          },
          "propertyNames": {
            "$ref": "#/$defs/WritebackStatus"
          },
          "title": "Writeback Counts",
          "type": "object"
        },
        "aggregate_status": {
          "anyOf": [
            {
              "$ref": "#/$defs/WritebackStatus"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "terminal_event_action_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Terminal Event Action Id"
        },
        "terminal_event_writeback_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Terminal Event Writeback Id"
        },
        "terminal_event_disposition": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceDisposition"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "terminal_event_confirmed": {
          "default": false,
          "title": "Terminal Event Confirmed",
          "type": "boolean"
        },
        "external_unsynced": {
          "default": false,
          "title": "External Unsynced",
          "type": "boolean"
        },
        "updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Updated At"
        }
      },
      "required": [
        "event_id",
        "closure_cycle",
        "disposition_policy"
      ],
      "title": "WritebackSummary",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Single source of truth reused by API / Verify / UI / CLOSED gate / stats.",
  "properties": {
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "plan_revision": {
      "title": "Plan Revision",
      "type": "integer"
    },
    "action_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Action Counts",
      "type": "object"
    },
    "jobs": {
      "items": {
        "$ref": "#/$defs/ActionExecutionJob"
      },
      "title": "Jobs",
      "type": "array"
    },
    "actions": {
      "items": {
        "$ref": "#/$defs/ExecutionActionView"
      },
      "title": "Actions",
      "type": "array"
    },
    "writeback_summary": {
      "anyOf": [
        {
          "$ref": "#/$defs/WritebackSummary"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    }
  },
  "required": [
    "event_id",
    "plan_revision"
  ],
  "title": "ExecutionSummary",
  "type": "object"
}
