{
  "$defs": {
    "SourceDisposition": {
      "description": "Normalized external disposition label; source_status_raw keeps the original.",
      "enum": [
        "pending",
        "processing",
        "contained",
        "completed",
        "suspended",
        "ignored",
        "unknown"
      ],
      "title": "SourceDisposition",
      "type": "string"
    },
    "SourceObjectKind": {
      "description": "Canonical source object kind used for the internal discriminated union.",
      "enum": [
        "incident",
        "alert",
        "asset",
        "log",
        "connector"
      ],
      "title": "SourceObjectKind",
      "type": "string"
    },
    "SourceReference": {
      "additionalProperties": false,
      "description": "Immutable snapshot reference to an external source object (intro §4.3).\n\nIdentity five-tuple is\n``(source_product, source_tenant_id, connector_id, source_kind, source_object_id)``.\nThe adapter-native ``source_object_type`` and opaque ``source_concurrency_token``\ndo NOT participate in identity.",
      "properties": {
        "source_kind": {
          "$ref": "#/$defs/SourceObjectKind"
        },
        "source_product": {
          "title": "Source Product",
          "type": "string"
        },
        "source_tenant_id": {
          "title": "Source Tenant Id",
          "type": "string"
        },
        "connector_id": {
          "title": "Connector Id",
          "type": "string"
        },
        "source_object_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Object Type"
        },
        "source_object_id": {
          "title": "Source Object Id",
          "type": "string"
        },
        "parent_source_object_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Source Object Id"
        },
        "source_status_raw": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Status Raw"
        },
        "source_disposition": {
          "$ref": "#/$defs/SourceDisposition",
          "default": "unknown"
        },
        "source_concurrency_token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Concurrency Token"
        },
        "source_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Updated At"
        },
        "schema_version": {
          "default": "1",
          "title": "Schema Version",
          "type": "string"
        },
        "ingested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ingested At"
        },
        "raw_payload_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Raw Payload Hash"
        }
      },
      "required": [
        "source_kind",
        "source_product",
        "source_tenant_id",
        "connector_id",
        "source_object_id"
      ],
      "title": "SourceReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "External incident. Related-object references are nullable and only filled\nwhen the adapter actually obtained the relationship (never inferred).",
  "properties": {
    "reference": {
      "$ref": "#/$defs/SourceReference"
    },
    "raw_payload": {
      "additionalProperties": true,
      "title": "Raw Payload",
      "type": "object"
    },
    "normalized": {
      "additionalProperties": true,
      "title": "Normalized",
      "type": "object"
    },
    "title": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Title"
    },
    "level": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Level"
    },
    "gpt_verdict_label": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Gpt Verdict Label"
    },
    "impacted_asset_refs": {
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Impacted Asset Refs",
      "type": "array"
    },
    "related_alert_refs": {
      "items": {
        "$ref": "#/$defs/SourceReference"
      },
      "title": "Related Alert Refs",
      "type": "array"
    }
  },
  "required": [
    "reference"
  ],
  "title": "SourceIncident",
  "type": "object"
}
