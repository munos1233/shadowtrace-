{
  "$defs": {
    "GraphEdge": {
      "additionalProperties": false,
      "properties": {
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "source_node_id": {
          "title": "Source Node Id",
          "type": "string"
        },
        "target_node_id": {
          "title": "Target Node Id",
          "type": "string"
        },
        "relation_type": {
          "$ref": "#/$defs/GraphRelationType"
        },
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "occurred_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Occurred At"
        }
      },
      "required": [
        "edge_id",
        "event_id",
        "source_node_id",
        "target_node_id",
        "relation_type",
        "evidence_id"
      ],
      "title": "GraphEdge",
      "type": "object"
    },
    "GraphNode": {
      "additionalProperties": false,
      "properties": {
        "node_id": {
          "title": "Node Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "entity_type": {
          "title": "Entity Type",
          "type": "string"
        },
        "entity_value": {
          "title": "Entity Value",
          "type": "string"
        },
        "properties": {
          "type": "object",
          "additionalProperties": true,
          "title": "Properties"
        }
      },
      "required": [
        "node_id",
        "event_id",
        "entity_type",
        "entity_value"
      ],
      "title": "GraphNode",
      "type": "object"
    },
    "GraphRelationType": {
      "enum": [
        "logged_in_from",
        "logged_in_to",
        "executed",
        "accessed",
        "connected_to",
        "resolved",
        "requested",
        "uploaded_to"
      ],
      "title": "GraphRelationType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "items": {
        "$ref": "#/$defs/GraphNode"
      },
      "title": "Nodes",
      "type": "array"
    },
    "edges": {
      "items": {
        "$ref": "#/$defs/GraphEdge"
      },
      "title": "Edges",
      "type": "array"
    },
    "central_entities": {
      "items": {
        "type": "string"
      },
      "title": "Central Entities",
      "type": "array"
    },
    "attack_path_candidates": {
      "items": {
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "title": "Attack Path Candidates",
      "type": "array"
    }
  },
  "title": "GraphOutput",
  "type": "object"
}
