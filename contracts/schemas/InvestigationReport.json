{
  "$defs": {
    "FinalVerdict": {
      "description": "Verdict label, independent from EventStatus.",
      "enum": [
        "none",
        "possible_false_positive",
        "false_positive",
        "confirmed_threat"
      ],
      "title": "FinalVerdict",
      "type": "string"
    },
    "ReportSection": {
      "additionalProperties": false,
      "description": "One chapter of the structured report.",
      "properties": {
        "key": {
          "title": "Key",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "content": {
          "default": "",
          "title": "Content",
          "type": "string"
        },
        "data": {
          "additionalProperties": true,
          "title": "Data",
          "type": "object"
        }
      },
      "required": [
        "key",
        "title"
      ],
      "title": "ReportSection",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "report_id": {
      "title": "Report Id",
      "type": "string"
    },
    "event_id": {
      "title": "Event Id",
      "type": "string"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/ReportSection"
      },
      "title": "Sections",
      "type": "array"
    },
    "final_verdict": {
      "$ref": "#/$defs/FinalVerdict",
      "default": "none"
    },
    "risk_score": {
      "default": 0,
      "maximum": 100,
      "minimum": 0,
      "title": "Risk Score",
      "type": "integer"
    },
    "severity": {
      "$ref": "#/$defs/Severity",
      "default": "low"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    },
    "generated_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated By"
    },
    "generated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated At"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    }
  },
  "required": [
    "report_id",
    "event_id",
    "title"
  ],
  "title": "InvestigationReport",
  "type": "object"
}
