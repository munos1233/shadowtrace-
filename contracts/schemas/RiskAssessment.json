        "$ref": "#/$defs/RiskFactor"
      },
      "title": "Risk Factors",
      "type": "array"
    },
    "possible_false_positive": {
      "default": false,
      "title": "Possible False Positive",
      "type": "boolean"
    },
    "scoring_mode": {
      "$ref": "#/$defs/ScoringMode"
    }
  },
  "required": [
    "risk_score",
    "severity",
    "confidence",
    "scoring_mode"
  ],
  "title": "RiskAssessment",
  "type": "object"
